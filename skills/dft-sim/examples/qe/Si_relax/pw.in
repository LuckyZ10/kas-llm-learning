&CONTROL
  calculation = 'relax'
  restart_mode = 'from_scratch'
  prefix = 'si'
  outdir = './tmp'
  pseudo_dir = './pseudo'
  tprnfor = .true.
  tstress = .true.
  forc_conv_thr = 1.0D-3
/
&SYSTEM
  ibrav = 2
  celldm(1) = 10.5
  nat = 2
  ntyp = 1
  ecutwfc = 40
  ecutrho = 320
  occupations = 'smearing'
  smearing = 'gaussian'
  degauss = 0.01
/
&ELECTRONS
  conv_thr = 1.0D-8
  mixing_beta = 0.7
/
&IONS
  ion_dynamics = 'bfgs'
/
ATOMIC_SPECIES
 Si 28.086 Si.pbe-n-kjpaw_psl.1.0.0.UPF

ATOMIC_POSITIONS alat
 Si 0.00 0.00 0.00
 Si 0.26 0.26 0.26

K_POINTS automatic
6 6 6 0 0 0
