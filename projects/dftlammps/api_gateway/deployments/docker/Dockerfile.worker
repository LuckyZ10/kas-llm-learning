# DFT-LAMMPS Celery Worker Dockerfile
FROM python:3.11-slim

WORKDIR /app

# 安装系统依赖
RUN apt-get update && apt-get install -y \
    build-essential \
    libopenmpi-dev \
    && rm -rf /var/lib/apt/lists/*

# 复制依赖文件
COPY requirements.txt .

# 安装Python依赖
RUN pip install --no-cache-dir -r requirements.txt

# 复制应用代码
COPY dftlammps/ ./dftlammps/

# 创建日志和数据目录
RUN mkdir -p /app/logs /app/data

# 设置环境变量
ENV PYTHONPATH=/app
ENV C_FORCE_ROOT=true

# 默认命令（会被docker-compose覆盖）
CMD ["celery", "-A", "dftlammps.api_gateway.tasks.celery_app", "worker", "--loglevel=info"]
