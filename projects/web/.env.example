# DFT-LAMMPS Web Platform Environment Variables

# Database Passwords (change these in production!)
POSTGRES_PASSWORD=dftlammps_secure_password_change_me
MONGODB_PASSWORD=mongodb_secure_password_change_me

# JWT Secret (generate a secure random string)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-32chars

# Default Admin Password (change immediately after first login!)
DEFAULT_ADMIN_PASSWORD=admin123

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Database URLs (used internally)
DATABASE_URL=postgresql://dftlammps:${POSTGRES_PASSWORD}@postgres:5432/dftlammps
MONGODB_URL=mongodb://admin:${MONGODB_PASSWORD}@mongodb:27017/

# Storage Paths
UPLOAD_DIR=/app/uploads
RESULTS_DIR=/app/results
STATIC_DIR=/app/static

# Frontend API URL (for development)
REACT_APP_API_URL=http://localhost/api/v1
