{
  "name": "dft-lammps-research",
  "version": "1.0.0",
  "description": "DFT + LAMMPS Multiscale Materials Simulation Framework",
  "main": "code_templates/end_to_end_workflow.py",
  "scripts": {
    "test": "pytest tests/",
    "workflow": "python code_templates/end_to_end_workflow.py",
    "dft": "python code_templates/dft_workflow.py",
    "ml-train": "python code_templates/ml_potential_training.py",
    "md": "python code_templates/md_simulation_lammps.py",
    "screening": "python code_templates/high_throughput_screening.py"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/user/dft-lammps-research.git"
  },
  "keywords": [
    "DFT",
    "LAMMPS",
    "molecular-dynamics",
    "machine-learning",
    "materials-science",
    "multiscale-modeling",
    "high-throughput",
    "computational-chemistry"
  ],
  "author": "Research Team",
  "license": "MIT",
  "dependencies": {
    "python": ">=3.9",
    "ase": ">=3.22.0",
    "pymatgen": ">=2023.0.0",
    "numpy": ">=1.24.0",
    "pandas": ">=2.0.0",
    "scipy": ">=1.10.0",
    "matplotlib": ">=3.7.0",
    "dpdata": ">=0.2.0",
    "fireworks": ">=2.0.0",
    "atomate": ">=1.0.0",
    "custodian": ">=2023.0.0",
    "matminer": ">=0.8.0",
    "dscribe": ">=2.0.0",
    "scikit-learn": ">=1.3.0",
    "torch": ">=2.0.0",
    "mp-api": ">=0.30.0"
  },
  "optional_dependencies": {
    "aiida": ["aiida-core>=2.0.0", "aiida-vasp>=3.0.0"],
    "deepmd": ["deepmd-kit>=2.2.0", "tensorflow>=2.12.0"],
    "lammps": ["lammps>=2023.0.0"],
    "viz": ["plotly>=5.0.0", "pythreejs>=2.0.0", "nglview>=3.0.0"]
  },
  "devDependencies": {
    "pytest": ">=7.0.0",
    "black": ">=23.0.0",
    "flake8": ">=6.0.0",
    "mypy": ">=1.0.0"
  }
}
