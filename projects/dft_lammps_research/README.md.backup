│
├── examples/                   # 示例代码
│   ├── basic/                 # 基础示例
│   ├── advanced/              # 高级示例
│   ├── active_learning/       # 主动学习示例
│   └── workflows/             # 完整工作流示例
│
├── tests/                      # 测试套件
│   ├── unit/                  # 单元测试
│   ├── integration/           # 集成测试
