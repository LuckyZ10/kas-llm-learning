│   ├── performance/           # 性能测试
│   ├── regression/            # 回归测试
│   └── benchmarks/            # 基准测试
│
├── docs/                       # 文档
│   ├── api/                   # API文档
│   ├── guides/                # 用户指南
│   └── architecture/          # 架构文档
│
├── scripts/                    # 工具脚本和配置
├── references/                 # 参考文献
└── tutorials/                  # 教程
