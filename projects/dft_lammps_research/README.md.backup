│   ├── ml/                    # 机器学习势 (NEP, DeepMD)
│   ├── common/                # 共享工具库
│   └── templates/             # 代码模板
│
├── workflows/                  # 应用工作流
│   ├── battery/               # 电池材料筛选
│   ├── catalyst/              # 催化剂设计
│   ├── perovskite/            # 钙钛矿材料
│   └── alloy/                 # 合金设计
│
├── platform/                   # 平台服务
│   ├── api/                   # REST API平台
│   ├── web/                   # Web用户界面
│   ├── hpc/                   # HPC集群连接器
